{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "lib": ["DOM", "ES2020"],
    "types": ["chrome", "react", "react-dom"],
    "skipLibCheck": true
  },
  "include": [    "background/**/*",
    "content-scripts/**/*",
    "popup/**/*",
    "src/**/*"]
}