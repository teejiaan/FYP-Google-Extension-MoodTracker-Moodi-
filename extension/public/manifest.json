{
  "manifest_version": 3,
  "name": "Moodi Mental State Monitor",
  "version": "1.0.0",
  "description": "Tracks browsing patterns to provide wellness insights.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "idle",
    "scripting",
    "identity",
    "windows",
    "alarms"
  ],
  "icons": {
    "16": "icons/moodi-logo.png",
    "32": "icons/moodi-logo.png",
    "48": "icons/moodi-logo.png",
    "128": "icons/moodi-logo.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/moodi-logo.png",
      "32": "icons/moodi-logo.png",
      "48": "icons/moodi-logo.png",
      "128": "icons/moodi-logo.png"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-scripts/observer.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "oauth2": {
    "client_id": "32586665803-7pkkjiotsbbts4nbh7pkmmgj894u2s1l.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  }
}
